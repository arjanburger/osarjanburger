---
interface Props {
    title: string;
    description?: string;
    bodyClass?: string;
    pageSlug: string;
}
const { title, description, bodyClass, pageSlug } = Astro.props;
const isDev = import.meta.env.DEV;
---
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700&family=Inter:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/js/player.css">
    <slot name="head" />
</head>
<body class={bodyClass}>
    <slot />

    {isDev && (
        <button id="editToggle" type="button" style="display:none;position:fixed;top:16px;right:16px;background:#111;color:#c8a55c;border:1px solid #c8a55c;padding:6px 12px;border-radius:6px;font-size:11px;font-weight:600;z-index:99999;cursor:pointer;font-family:-apple-system,sans-serif;letter-spacing:0.05em;">
            EDIT
        </button>
    )}

    <script is:inline src="/js/engine.js" data-page={pageSlug}></script>
    <script is:inline src="/js/player.js"></script>
    {isDev && <script is:inline src="/edit-mode.js"></script>}
    <slot name="scripts" />
</body>
</html>
