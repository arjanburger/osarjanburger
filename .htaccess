RewriteEngine On

# Statische bestanden direct serveren
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ── flow.arjanburger.com ─────────────────────────────────
# Statische bestanden: /js/engine.js → flow/public/js/engine.js
RewriteCond %{HTTP_HOST} ^flow\. [NC]
RewriteCond %{DOCUMENT_ROOT}/flow/public%{REQUEST_URI} -f
RewriteRule ^(.*)$ flow/public/$1 [L]

# Landing pages: /doorbraak → flow/public/doorbraak/index.html
RewriteCond %{HTTP_HOST} ^flow\. [NC]
RewriteCond %{DOCUMENT_ROOT}/flow/public%{REQUEST_URI}/index.html -f
RewriteRule ^(.*)$ flow/public/$1/index.html [L]

# Flow root → redirect naar arjanburger.com
RewriteCond %{HTTP_HOST} ^flow\. [NC]
RewriteRule ^$ https://arjanburger.com [R=301,L]

# Flow deploy webhook
RewriteCond %{HTTP_HOST} ^flow\. [NC]
RewriteRule ^deploy\.php$ flow/public/deploy.php [L,QSA]

# ── os.arjanburger.com ───────────────────────────────────
# API requests → api/public/index.php
RewriteRule ^api/public/(.*)$ api/public/index.php [L,QSA]

# OS requests via prefix
RewriteRule ^os/public/(.*)$ os/public/index.php [L,QSA]

# Root → OS dashboard
RewriteCond %{HTTP_HOST} !^flow\. [NC]
RewriteRule ^$ os/public/index.php [L]

# Clean URLs: /login, /dashboard, /clients etc → os/public/index.php
RewriteCond %{HTTP_HOST} !^flow\. [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(login|verify|dashboard|clients|pages|analytics|logout)(.*)$ os/public/index.php [L,QSA]
